  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{label_plain} Personal — uniworks für Unternehmen</title>
  <meta name="description" content="uniworks stellt Ihnen flexibles, zuverlässiges {label_plain}-Personal aus motivierten Studierenden bereit. Jetzt Personalanfrage stellen." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- CDN: Google Fonts (IBM Plex Sans) — not offline-clean -->
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <!-- CDN: Tabler icons webfont — not offline-clean -->
