def nav_dd_items(active):
    rows = [
        '          <a href="index.html" role="menuitem">'
        '<i class="ti ti-layout-grid" aria-hidden="true"></i>Übersicht</a>'
    ]
    for slug, icon, label in NAV:
        cls = ' class="active"' if slug == active else ''
        rows.append(
            f'          <a href="{slug}.html"{cls} role="menuitem">'
            f'<i class="ti {icon}" aria-hidden="true"></i>{label}</a>'
        )
    return "\n".join(rows)


def nav_mob_items(active):
    rows = [
        '        <a href="index.html">'
        '<i class="ti ti-layout-grid" aria-hidden="true"></i>Übersicht</a>'
    ]
    for slug, icon, label in NAV:
        rows.append(
            f'        <a href="{slug}.html"><i class="ti {icon}" aria-hidden="true"></i>{label}</a>'
        )
    return "\n".join(rows)


def ref_imgs(logos=None):
    return "\n".join(
        f'        <img src="../../images/logos/{f}" alt="{alt}" loading="lazy" />'
        for f, alt in (logos or REF_LOGOS)
    )


def partner_imgs():
    return "\n".join(
        f'      <img src="../../images/logos/{f}" alt="{alt}" loading="lazy" />'
        for f, alt in PARTNER_LOGOS
    )


def footer_branchen():
    return "\n".join(
        f'          <li><a href="{slug}.html">{label}</a></li>'
        for slug, _, label in NAV
    )


TEMPLATE = """<!DOCTYPE html>
<html lang="de">
<head>
