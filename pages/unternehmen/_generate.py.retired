              <div class="field">
                <label for="f-zeitraum">Zeitraum / Dauer</label>
                <input id="f-zeitraum" name="zeitraum" type="text" placeholder="z.&nbsp;B. 3 Tage, ab sofort" />
                <span class="field-error" data-error="zeitraum"></span>
              </div>
              <div class="field full">
                <label for="f-nachricht">Nachricht</label>
                <textarea id="f-nachricht" name="nachricht" placeholder="Beschreiben Sie kurz Ihren Bedarf, gewünschte Qualifikationen oder Schichtzeiten."></textarea>
              </div>
              <div class="consent">
                <input id="f-consent" name="consent" type="checkbox" />
                <label for="f-consent">Ich stimme zu, dass meine Angaben zur Bearbeitung der Anfrage verarbeitet werden. <a href="#">Datenschutz</a>. <span class="req">*</span></label>
              </div>
              <span class="field-error" data-error="consent" style="grid-column:1/-1"></span>
            </div>
            <button type="submit" class="btn btn-p">Personalanfrage senden</button>
            <div class="form-status" id="form-status" role="alert"></div>
            <p class="form-note">Mit&nbsp;* markierte Felder sind Pflichtfelder.</p>
          </form>

          <div class="form-success" id="form-success" role="status">
            <div class="ok"><i class="ti ti-check" aria-hidden="true"></i></div>
            <h3>Vielen Dank für Ihre Anfrage!</h3>
            <p>Wir haben Ihre Personalanfrage erhalten und melden uns zeitnah mit einem passenden Angebot bei Ihnen.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PARTNER BAND ── -->
  <section class="ptrs">
