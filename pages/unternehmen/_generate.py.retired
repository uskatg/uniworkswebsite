              <div class="field">
                <label for="f-anzahl">Anzahl Mitarbeiter:innen <span class="req">*</span></label>
                <input id="f-anzahl" name="anzahl" type="number" min="1" inputmode="numeric" placeholder="z.&nbsp;B. 5" />
                <span class="field-error" data-error="anzahl"></span>
              </div>
              <div class="field">
                <label for="f-einsatzort">Einsatzort <span class="req">*</span></label>
                <input id="f-einsatzort" name="einsatzort" type="text" placeholder="PLZ / Ort" />
