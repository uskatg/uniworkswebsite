#!/usr/bin/env python3
"""RETIRED — do NOT run. Kept for reference only.

This was the generator for the "Für Unternehmen" branch subpages. As of
2026-06-05 the workflow moved to editing each pages/unternehmen/*.html file
by hand, and several pages now carry custom content that is NOT in DATA below
(e.g. einzelhandel's "voices" testimonial + real client logos, event's Adele
hero + concert logos, gastronomie-hotellerie's review section).

Running this script would OVERWRITE those hand edits from the stale DATA, so it
has been retired (renamed to _generate.py.retired and guarded below). The 7
pages are now maintained directly; keep the Personalanfrage <form> identical
across them when editing by hand.

Original generator description:
  Emitted one static HTML file per industry into this folder, keeping the 7
  pages identical except for per-industry content (TEMPLATE + DATA).
"""
import sys

sys.exit(
    "RETIRED: pages/unternehmen/*.html are now hand-maintained. "
    "Running this generator would clobber custom page content. "
    "Remove this guard intentionally if you ever revive it."
)

import os

HERE = os.path.dirname(os.path.abspath(__file__))

