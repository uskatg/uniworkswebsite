{partner_imgs}
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="footer">
    <div class="wrap">
      <div class="footer-grid">
        <div class="footer-col">
          <div class="footer-brand">
            <img src="../../images/branding/AppIcon.webp" alt="uniworks" />
            <span>uniworks</span>
          </div>
          <p>Deutschlands schnellst wachsender Personaldienstleister — wir verbinden Unternehmen mit motivierten Studierenden.</p>
        </div>
        <div class="footer-col">
          <h4>uniworks</h4>
          <ul>
            <li><a href="../index.html">Startseite</a></li>
            <li><a href="../index.html">Für Studierende</a></li>
            <li><a href="../about.html">Über Uns</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>Branchen</h4>
          <ul>
{footer_branchen}
          </ul>
        </div>
        <div class="footer-col">
          <h4>Rechtliches</h4>
          <ul>
            <li><a href="#">Impressum</a></li>
            <li><a href="#">Datenschutz</a></li>
            <li><a href="https://www.instagram.com/uniworks.gmbh">Instagram</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <span>Copyright © 2026 uniworks GmbH. Alle Rechte vorbehalten.</span>
        <span>München</span>
      </div>
    </div>
  </footer>

  <script src="branche.js"></script>{foot_extra}
</body>
</html>
"""


def label_plain(label):
    return label.replace("&amp;", "&")


def render(slug, d):
    lp = label_plain(d["label"])
    tf = d.get("typeform")
    if tf:
        # Logistik: hero CTA opens the conversational (Typeform-style) flow;
        # secondary jumps to the classic inline form further down.
        body_attr = f' data-tf-branche="{lp}"'
        head_extra = '  <link rel="stylesheet" href="typeform-flow.css" />\n'
        foot_extra = '\n  <script src="typeform-flow.js"></script>'
        hero_cta = (
            '<div class="bhero-btns">\n'
            '          <button type="button" class="btn btn-p" data-tf-open>Personalanfrage stellen</button>\n'
            '          <a href="#anfrage" class="btn btn-s">Klassisches Formular</a>\n'
            '        </div>'
        )
        anfrage_extra = (
            '\n          <p style="margin-top:24px"><button type="button" class="btn btn-s" data-tf-open>'
            '<i class="ti ti-messages" aria-hidden="true"></i> Lieber im Dialog ausfüllen</button></p>'
        )
    else:
        body_attr = ''
        head_extra = ''
        foot_extra = ''
        hero_cta = (
            '<div class="bhero-btns">\n'
            '          <a href="#anfrage" class="btn btn-p">Personalanfrage stellen</a>\n'
            '          <a href="../about.html" class="btn btn-s">Über uniworks</a>\n'
            '        </div>'
        )
        anfrage_extra = ''

    return TEMPLATE.format(
        label=d["label"],
        label_plain=lp,
        icon=d["icon"],
        img=d["img"],
        h1=d["h1"],
        lead=d["lead"],
        roles=d["roles"],
        nav_dd=nav_dd_items(slug),
        nav_mob=nav_mob_items(slug),
        ref_imgs=ref_imgs(REF_LOGOS_BY_SLUG.get(slug)),
        partner_imgs=partner_imgs(),
        footer_branchen=footer_branchen(),
        body_attr=body_attr,
        head_extra=head_extra,
        foot_extra=foot_extra,
        hero_cta=hero_cta,
        anfrage_extra=anfrage_extra,
    )


def main():
    for slug, _, _ in NAV:
        html = render(slug, DATA[slug])
        path = os.path.join(HERE, slug + ".html")
        with open(path, "w", encoding="utf-8") as fh:
            fh.write(html)
        print("wrote", os.path.relpath(path))


if __name__ == "__main__":
    main()
