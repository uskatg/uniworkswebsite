{ref_imgs}
      </div>
    </div>
  </section>

  <!-- ── PERSONALANFRAGE (custom request form) ── -->
  <section class="anfrage" id="anfrage">
    <div class="wrap">
      <div class="anfrage-grid">
        <div class="anfrage-intro">
          <h2>Senden Sie uns Ihre Personalanfrage.</h2>
          <p>Teilen Sie uns mit, wie viel Personal Sie wann und wo benötigen, wir melden uns zeitnah mit einem Angebot, das Ihre Wünsche berücksichtigt.</p>
          <ul class="anfrage-points">
            <li><i class="ti ti-clock-hour-4" aria-hidden="true"></i>Antwort in der Regel innerhalb von 24&nbsp;Stunden</li>
            <li><i class="ti ti-users" aria-hidden="true"></i>Geprüfte, motivierte Studierende</li>
